# ===========================================
# Union Alkimia - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# For Dokploy: paste these in the Environment tab

# --- Database (used by docker-compose internally) ---
POSTGRES_DB=union_alkimia
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password-here

# --- Auth ---
NEXTAUTH_URL=https://union.wyweb.net
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_TRUST_HOST=true

# --- MinIO (S3-compatible storage) ---
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=union-alkimia

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Resend (Email) ---
RESEND_API_KEY=re_...
FROM_EMAIL=Union Alkimia <noreply@unionalkimia.com>

# --- Push Notifications (VAPID) ---
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@unionalkimia.com

# --- Cron ---
CRON_SECRET=generate-with-openssl-rand-base64-32
